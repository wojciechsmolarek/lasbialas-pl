---
import { useTranslations } from '../../i18n/utils';
import { Picture } from 'astro:assets';

interface Props {
  lang: 'pl' | 'en' | 'de';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const galleryImages = [
  {
    src: '/foto/webp-1280/lasbialas1.webp',
    alt: lang === 'pl' ? 'Widok na domek Las Biala\'s' : lang === 'en' ? 'View of Las Biala\'s cottage' : 'Ansicht des Ferienhauses Las Biala\'s',
    tooltip: t('gallery.cabin_with_jacuzzi'),
    index: 0,
    loading: 'lazy' as const
  },
  {
    src: '/foto/webp-1280/lasbialas2.webp',
    alt: lang === 'pl' ? 'Dwa domki w Puszczy Noteckiej' : lang === 'en' ? 'Two cottages in Noteć Forest' : 'Zwei Ferienhäuser in der Puszcza Notecka',
    tooltip: t('gallery.two_cabins'),
    index: 1,
    loading: 'lazy' as const
  },
  {
    src: '/foto/webp-1280/lasbialas7.webp',
    alt: lang === 'pl' ? 'Sauna Las Biala\'s w lesie' : lang === 'en' ? 'Las Biala\'s sauna in the forest' : 'Las Biala\'s Sauna im Wald',
    tooltip: t('gallery.sauna'),
    index: 6,
    fetchpriority: 'high'
  },
  {
    src: '/foto/webp-1280/lasbialas5.webp',
    alt: lang === 'pl' ? 'Duża sypialnia dla 2 osób' : lang === 'en' ? 'Large bedroom for 2 people' : 'Großes Schlafzimmer für 2 Personen',
    tooltip: t('gallery.bedrooms'),
    index: 4,
    loading: 'lazy' as const
  },
  {
    src: '/foto/webp-1280/lasbialas4.webp',
    alt: lang === 'pl' ? 'Widok salonu w domku' : lang === 'en' ? 'View of the living room' : 'Ansicht des Wohnzimmers',
    tooltip: t('gallery.living_room_amenities'),
    index: 3,
    loading: 'lazy' as const
  },
  {
    src: '/foto/webp-1280/lasbialas6.webp',
    alt: lang === 'pl' ? 'Mała sypialnia dla 2 osób z telewizorem oraz łazienka i prysznicem' : lang === 'en' ? 'Small bedroom for 2 with TV and bathroom' : 'Kleines Schlafzimmer für 2 mit TV und Bad',
    tooltip: t('gallery.sauna_cooling'),
    index: 5,
    loading: 'lazy' as const
  },
  {
    src: '/foto/webp-1280/lasbialas3.webp',
    alt: lang === 'pl' ? 'Widok salonu w domku' : lang === 'en' ? 'Living room view' : 'Wohnzimmer Ansicht',
    tooltip: t('gallery.living_room'),
    index: 2,
    fetchpriority: 'high'
  },
  {
    src: '/foto/webp-1280/lasbialas8.webp',
    alt: lang === 'pl' ? 'Domki na wynajem w Białej' : lang === 'en' ? 'Cottages for rent in Biała' : 'Ferienhäuser zur Miete in Biała',
    tooltip: t('gallery.guest_cottages'),
    index: 7,
    fetchpriority: 'high'
  }
];
---

<div class="grid grid-cols-4 gap-[7px] mt-2.5 mb-2.5 max-[1024px]:grid-cols-2">
  {
    galleryImages.map((image) => (
      <div class="relative inline-block group cursor-pointer" onclick={`openImage(${image.index})`}>
        <Picture
          src={image.src}
          alt={image.alt}
          width={834}
          height={470}
          formats={['avif', 'webp']}
          sizes="(max-width: 1024px) 50vw, 25vw"
          loading={image.loading || undefined}
          fetchpriority={image.fetchpriority as 'high' | 'low' | 'auto' | undefined}
          class="block w-full h-auto object-cover transition-transform duration-200"
        />
        <span class="invisible opacity-0 w-[320px] bg-black/70 text-white text-center rounded-[5px] p-[5px] absolute top-1/2 left-1/2 -translate-x-1/2 translate-y-[65px] transition-opacity duration-300 font-[Arial] text-[14px] font-normal leading-[1.4] z-[1] pointer-events-none group-hover:visible group-hover:opacity-100 max-[768px]:hidden">{image.tooltip}</span>
      </div>
    ))
  }
</div>

<script>
  // Lazy load lightbox only when user interacts with gallery
  let lightboxLoaded = false;
  function loadLightboxAndOpen(index: number) {
    if (lightboxLoaded && typeof (window as any).openImage === 'function') {
      (window as any).openImage(index);
      return;
    }
    import('../../scripts/lightbox').then(() => {
      lightboxLoaded = true;
      if (typeof (window as any).openImage === 'function') {
        (window as any).openImage(index);
      }
    });
  }
  // Override onclick handlers with lazy-loaded version (deferred)
  function initGalleryClickHandlers() {
    document.querySelectorAll('[onclick^="openImage"]').forEach(el => {
      const onclickAttr = el.getAttribute('onclick') || '';
      const match = onclickAttr.match(/openImage\((\d+)\)/);
      if (match) {
        const idx = parseInt(match[1], 10);
        el.removeAttribute('onclick');
        el.addEventListener('click', function(e) {
          e.preventDefault();
          loadLightboxAndOpen(idx);
        });
      }
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGalleryClickHandlers, { once: true });
  } else {
    initGalleryClickHandlers();
  }
</script>
