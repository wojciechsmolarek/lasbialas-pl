---
import { Picture } from 'astro:assets';
import lasbialasJacuzzi1 from '../../assets/foto/lasbialas-jacuzzi1.webp';
import sauna1 from '../../assets/foto/sauna1.webp';
import lasbialas1 from '../../assets/foto/lasbialas1.webp';
import sauna4 from '../../assets/foto/sauna4.webp';
import sauna5 from '../../assets/foto/sauna5.webp';
import lasbialasJacuzzi2 from '../../assets/foto/lasbialas-jacuzzi2.webp';
import sauna7 from '../../assets/foto/sauna7.webp';
import lasbialasJacuzzi3 from '../../assets/foto/lasbialas-jacuzzi3.webp';

interface Props {
  lang: 'pl' | 'en' | 'de';
}

const { lang } = Astro.props;

const images = [lasbialasJacuzzi1, sauna1, lasbialas1, sauna4, sauna5, lasbialasJacuzzi2, sauna7, lasbialasJacuzzi3];

const t = {
  pl: {
    alt: ['Jacuzzi w lesie przy domku','Sauna przy domkach Las Bialas','Jacuzzi przy tarasie domku D2','Kolorowe oświetlenie w saunie','Sauna w lesie','Jacuzzi z LED','Podświetlenie LED w saunie','Jacuzzi w ogrodzie przy domku'],
    tip: ['Jacuzzi przy domku D1','Sauna Las Bialas w Puszczy Noteckiej','Jacuzzi przy tarasie domku D2','Podświetlenie LED w saunie','Sauna w lesie','Jacuzzi z funkcją automatycznego podgrzewania wody, aeromasażem i wielokolorowym podświetleniem LED','Podświetlenie LED w saunie','Jacuzzi w ogrodzie przy domku'],
  },
  en: {
    alt: ['Jacuzzi in the forest by the cabin','Sauna by the cabins','Jacuzzi by terrace of cabin D2','Colorful lighting in sauna','Sauna in the forest','Jacuzzi with LED','LED lighting in sauna','Jacuzzi in garden by cabin'],
    tip: ['Jacuzzi by cabin D1','Sauna Las Bialas in Noteć Forest','Jacuzzi by terrace of cabin D2','LED lighting in sauna','Sauna in the forest','Jacuzzi with automatic heating, air massage and LED','LED lighting in sauna','Jacuzzi in garden by cabin'],
  },
  de: {
    alt: ['Jacuzzi im Wald beim Haus','Sauna bei den Ferienhäusern','Jacuzzi an der Terrasse des Hauses D2','Farbige Beleuchtung in der Sauna','Sauna im Wald','Jacuzzi mit LED','LED-Licht in der Sauna','Jacuzzi im Garten beim Haus'],
    tip: ['Jacuzzi beim Haus D1','Sauna Las Bialas in der Puszcza Notecka','Jacuzzi an der Terrasse des Hauses D2','LED-Beleuchtung in der Sauna','Sauna im Wald','Jacuzzi mit automatischer Wassererwärmung, Luftmassage und LED','LED-Beleuchtung in der Sauna','Jacuzzi im Garten beim Haus'],
  },
}[lang];
---

<div class="grid grid-cols-4 gap-[7px] mt-2.5 mb-2.5 max-[1024px]:grid-cols-2">
  {[8,9,10,11,12,13,14,15].map((i, idx) => (
    <div class="relative inline-block group">
      <Picture src={images[idx]} alt={t.alt[idx]} width={834} height={470} formats={['avif', 'webp']} sizes="(max-width: 1024px) 50vw, 25vw" loading="lazy" decoding="async" onclick={`openImage(${i})`} class="block w-full h-auto object-cover cursor-pointer transition-transform duration-200" />
      <span class="invisible opacity-0 w-[320px] bg-black/70 text-white text-center rounded-[5px] p-[5px] absolute top-1/2 left-1/2 -translate-x-1/2 translate-y-[65px] transition-opacity duration-300 font-[Arial] text-[14px] font-normal leading-[1.4] z-[1] pointer-events-none group-hover:visible group-hover:opacity-100 max-[768px]:hidden">{t.tip[idx]}</span>
    </div>
  ))}
</div>
