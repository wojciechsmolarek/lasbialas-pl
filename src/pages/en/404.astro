---
import PageLayout from '../../layouts/PageLayout.astro';
const lang = 'en';
---

<PageLayout
  title="404 - Page Not Found | Las Biala's"
  description="The page you are looking for was not found."
  lang={lang}
>
  <div class="container mx-auto max-w-3xl px-4 py-24 text-center">
    <h1 class="mb-4 text-9xl font-bold">404</h1>
    <h2 class="mb-8 text-3xl font-semibold">Page Not Found</h2>
    <p class="mb-8 text-lg">Sorry, the page you are looking for does not exist.</p>
    <a href="/en/" class="inline-block bg-primary-green px-6 py-3 text-white hover:bg-green-700">
      Return to homepage
    </a>
  </div>
</PageLayout>
