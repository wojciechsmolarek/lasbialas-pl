---
import { SEO } from 'astro-seo';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: 'pl' | 'en' | 'de';
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  lang = 'pl',
  canonical,
  ogImage = '/foto/lasbialas8.webp'
} = Astro.props;

const siteUrl = 'https://lasbialas.pl';

// Generate hreflang links
const hreflangs = [
  { lang: 'pl', url: lang === 'pl' ? siteUrl : `${siteUrl}/` },
  { lang: 'en', url: `${siteUrl}/en/` },
  { lang: 'de', url: `${siteUrl}/de/` },
  { lang: 'x-default', url: siteUrl }
];
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="robots" content="noindex, nofollow" />

    <!-- Preconnect to external domains -->
    <link rel="preconnect" href="https://cdn.bookero.pl" />
    <link rel="dns-prefetch" href="https://cdn.bookero.pl" />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://collect.yabrix.com" />
    <link rel="dns-prefetch" href="https://collect.yabrix.com" />

    <SEO
      title={title}
      description={description}
      canonical={canonical || `${siteUrl}${Astro.url.pathname}`}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: `${siteUrl}${ogImage}`,
          url: canonical || `${siteUrl}${Astro.url.pathname}`
        },
        image: {
          width: 1200,
          height: 1200
        }
      }}
    />

    <!-- Hreflang -->
    {hreflangs.map(({ lang: hreflangLang, url }) => (
      <link rel="alternate" hreflang={hreflangLang} href={url} />
    ))}

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />

    <!-- Font Preload - only primary weight to avoid blocking -->
    <link
      rel="preload"
      href="/fonts/Montserrat-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <!-- Schema.org Structured Data -->
    <SchemaOrg lang={lang} />

    <!-- Yabrix Analytics -->
    <script
      src="https://collect.yabrix.com/js/yabrix.min.js"
      data-yx="1f3667d27b92c8b9"
      defer
      is:inline
    ></script>

    <!-- Google Analytics (Lazy Load) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }

      function loadAnalytics() {
        var script = document.createElement('script');
        script.src = 'https://www.googletagmanager.com/gtag/js?id=G-R3P2XT4WY8';
        script.defer = true;
        document.head.appendChild(script);

        gtag('js', new Date());
        gtag('config', 'G-R3P2XT4WY8', { anonymize_ip: true });
      }

      window.addEventListener('scroll', loadAnalytics, { once: true });
      window.addEventListener('mousemove', loadAnalytics, { once: true });
      window.addEventListener('touchstart', loadAnalytics, { once: true });
    </script>

    <!-- Bookero Reservation System -->
    <script is:inline define:vars={{ lang }}>
      // Bookero configuration
      window.bookero_config = {
        id: 'WmRe79H4lKFz',
        container: 'bookero',
        type: 'sticky',
        position: 'bottom-right',
        plugin_css: true,
        lang: lang
      };

      var bookeroLoaded = false;
      var bookeroPendingClick = false;

      function loadBookeroScript() {
        if (bookeroLoaded) return;
        bookeroLoaded = true;
        var d = document, s = d.createElement('script');
        s.src = 'https://cdn.bookero.pl/plugin/v2/js/bookero-compiled.js';
        s.onload = function() {
          // Hide fallback button once Bookero loads its own toggle
          var fallback = document.getElementById('bookero-sticky-fallback');
          if (fallback) fallback.style.display = 'none';
          if (bookeroPendingClick) {
            bookeroPendingClick = false;
            setTimeout(function() {
              if (typeof window.bookero_open === 'function') {
                window.bookero_open();
              } else {
                var toggle = document.querySelector('.bookero-sticky-plugin-toggle');
                if (toggle) toggle.click();
              }
            }, 200);
          }
        };
        d.body.appendChild(s);
      }

      // Only load on user interaction, not on page load
      window.openReservation = function() {
        if (bookeroLoaded) {
          if (typeof window.bookero_open === 'function') {
            window.bookero_open();
            return;
          }
          if (window.Bookero && window.Bookero.API && typeof window.Bookero.API.openCalendar === 'function') {
            window.Bookero.API.openCalendar();
            return;
          }
          var toggle = document.querySelector('.bookero-sticky-plugin-toggle');
          if (toggle) toggle.click();
        } else {
          bookeroPendingClick = true;
          loadBookeroScript();
        }
      };
    </script>

    <!-- Bookero Validation (Minimum 2 nights) -->
    <script is:inline>
      (function() {
        function enforceMinimumDays() {
          var daysInput = document.getElementById('bookero-plugin-days-number');
          if (daysInput) {
            var days = parseInt(daysInput.value) || 10;
            if (days < 2) {
              setTimeout(function () {
                daysInput.value = 2;
                setTimeout(function () {
                  var event = new Event('input');
                  daysInput.dispatchEvent(event);
                }, 100);
              }, 100);
            }
          }
        }

        function initValidation() {
          document.body.addEventListener('bookero-plugin:days-changed', function () {
            enforceMinimumDays();
          });

          document.body.addEventListener('bookero-plugin:service-updated', function () {
            enforceMinimumDays();
          });

          document.body.addEventListener('bookero-plugin:loaded', function () {
            enforceMinimumDays();
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initValidation);
        } else {
          initValidation();
        }
      })();
    </script>

    <slot name="head" />
  </head>
  <body class="font-sans font-light">
    <div id="bookero"></div>

    <!-- Sticky reservation button - visible until Bookero loads its own -->
    <button
      id="bookero-sticky-fallback"
      onclick="openReservation()"
      class="fixed bottom-0 right-0 z-[99998] bg-[#2F6940] text-white border-0 cursor-pointer font-montserrat transition-colors hover:bg-[#40a95c]"
      style="width:220px;height:56px;opacity:0.96;margin-bottom:3px;font-size:large;border-radius:0;"
    >
      {lang === 'pl' ? 'Rezerwuj' : lang === 'en' ? 'Book Now' : 'Reservieren'}
    </button>
    <style>
      @media (max-width: 960px) {
        #bookero-sticky-fallback {
          width: 100vw !important;
          max-width: 100vw !important;
          height: 60px !important;
          margin-bottom: 0 !important;
          bottom: 0 !important;
          left: 0 !important;
          right: 0 !important;
          border-radius: 0 !important;
        }
      }
    </style>
    <slot />
  </body>
</html>
