---
import { useTranslations } from '../../i18n/utils';
import { Picture } from 'astro:assets';

interface Props {
  lang: 'pl' | 'en' | 'de';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const icons = {
  sauna: '/foto/sauna-dla-gosci.png',
  jacuzzi: '/foto/jacuzzi.png',
};

const guideHref = {
  pl: 'https://lasbialas.pl/info/#/na-miejscu/32',
  en: 'https://lasbialas.pl/info/en/#/on-site/32',
  de: 'https://lasbialas.pl/info/de/#/vor-ort/32',
}[lang];

const jacuzziHref = {
  pl: 'https://lasbialas.pl/info/#/na-miejscu/385',
  en: 'https://lasbialas.pl/info/en/#/on-site/385',
  de: 'https://lasbialas.pl/info/de/#/vor-ort/385',
}[lang];
---

<div class="flex justify-center gap-[10px] flex-wrap my-[30px] mx-auto max-w-[73%] max-[768px]:gap-[20px] max-[768px]:max-w-[96%]">
  <div class="flex-[1_1_48%] border border-[#ccc] rounded-[5px] p-5 text-white text-base text-center leading-[1.6] box-border bg-gradient-to-b from-[#6b6767c6] to-[#3c3939c6] max-[768px]:flex-[1_1_100%] max-[768px]:max-w-[96vw] max-[768px]:mb-5">
    <div class="text-center mb-[5px]">
      <Picture alt="Sauna" height={60} width={60} src={icons.sauna} formats={['avif', 'webp']} class="inline-block" />
    </div>
    <h2 class="text-center mt-[5px] mb-5 text-white text-[24px] font-bold">{t('section.sauna_title')}</h2>
    <p class="text-base leading-[1.6]">{t('section.sauna_desc')}</p>
    <div class="flex justify-center mt-[30px]">
      <a class="inline-flex justify-center items-center w-auto h-[46px] text-base font-normal text-white bg-[#E97E2D] border-none text-center no-underline normal-case cursor-pointer mb-[30px] mt-[10px] px-[15px] hover:bg-[#c4621a] transition-colors" href={guideHref} target="_blank">{t('button.sauna_rules')}</a>
    </div>
  </div>
  <div class="flex-[1_1_48%] border border-[#ccc] rounded-[5px] p-5 text-white text-base text-center leading-[1.6] box-border bg-gradient-to-b from-[#3c9b55cc] to-[#2F6940] max-[768px]:flex-[1_1_100%] max-[768px]:max-w-[96vw] max-[768px]:mb-5">
    <div class="text-center mb-[5px]">
      <Picture alt="Jacuzzi" height={60} width={60} src={icons.jacuzzi} formats={['avif', 'webp']} class="inline-block" />
    </div>
    <h2 class="text-center mt-[5px] mb-5 text-white text-[24px] font-bold">{t('section.jacuzzi_title')}</h2>
    <p class="text-base leading-[1.6]">{t('section.jacuzzi_desc')}</p>
    <div class="flex justify-center mt-[30px]">
      <a class="inline-flex justify-center items-center w-auto h-[46px] text-base font-normal text-white bg-[#E97E2D] border-none text-center no-underline normal-case cursor-pointer mb-[30px] mt-[10px] px-[15px] hover:bg-[#c4621a] transition-colors" href={jacuzziHref} target="_blank">{t('button.jacuzzi_rules')}</a>
    </div>
  </div>
</div>
