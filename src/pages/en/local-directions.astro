---
import PageLayout from '../../layouts/PageLayout.astro';
const lang = 'en';
---

<PageLayout
  title="Directions to Las Biala's | Biała, Noteć Forest"
  description="How to get to Las Biala's cottages in Biała. By car, train, maps."
  lang={lang}
>
  <div class="container mx-auto max-w-3xl px-4 py-12">
    <h1 class="mb-8 text-4xl font-semibold">Directions</h1>
    <div class="prose prose-lg">
      <h2>By Car</h2>
      <p>Address: Biała 32, 64-730 Biała, Poland</p>
      <h2>By Train</h2>
      <p>Nearest station: Miały (10 km). Transfer provided.</p>
    </div>
  </div>
</PageLayout>
