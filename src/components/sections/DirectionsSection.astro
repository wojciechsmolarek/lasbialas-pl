---
import { Picture } from 'astro:assets';

interface Props {
  lang: 'pl' | 'en' | 'de';
}

const { lang } = Astro.props;

const t = {
  pl: {
    carTitle: 'Dojazd samochodem',
    carBtn: 'Wyznacz trasę',
    carText: 'Godzinę przyjazdu i wyjazdu uzgadniamy indywidualnie. Nie obsługujemy check-inów automatycznych.',
    trainTitle: 'Dojazd pociągiem',
    trainBtn: 'Do stacji kolejowej MIAŁY',
    trainText: 'Transfer ze stacji kolejowej Miały (10 km od Białej) do domków i z powrotem - bezpłatnie dla Gości korzystających z kolei.',
    locationTitle: 'Nasza lokalizacja',
    locationText: '64-730 Biała, Puszcza Notecka, Wielkopolska',
    mapBtn: 'Mapka dojazdu na miejscu',
    mapHref: '/dojazd',
  },
  en: {
    carTitle: 'By Car',
    carBtn: 'Plan route',
    carText: 'Arrival and departure times are arranged individually. We do not handle automatic check-ins.',
    trainTitle: 'By Train',
    trainBtn: 'To MIAŁY station',
    trainText: 'Transfer from Miały railway station (10 km from Biała) to the cottages and back - free for guests using the train.',
    locationTitle: 'Our Location',
    locationText: '64-730 Biała, Noteć Forest, Greater Poland',
    mapBtn: 'Local access map',
    mapHref: '/en/local-directions.html',
  },
  de: {
    carTitle: 'Mit dem Auto',
    carBtn: 'Route planen',
    carText: 'Ankunfts- und Abfahrtszeiten werden individuell vereinbart. Wir bieten keine automatischen Check-ins an.',
    trainTitle: 'Mit dem Zug',
    trainBtn: 'Zum Bahnhof MIAŁY',
    trainText: 'Transfer vom Bahnhof Miały (10 km von Biała entfernt) zu den Häusern und zurück - kostenlos für Gäste, die mit dem Zug anreisen.',
    locationTitle: 'Unsere Lage',
    locationText: '64-730 Biała, Puszcza Notecka, Großpolen',
    mapBtn: 'Karte - Anfahrt vor Ort',
    mapHref: '/de/anfahrt-vor-ort.html',
  },
}[lang];

const carHref = 'https://www.google.com/maps/dir//52.8265399,16.3041079/@52.8200488,16.3011326,2526m/data=!3m1!1e3!4m2!4m1!3e0?hl=pl&entry=ttu';
const trainHref = 'https://www.google.pl/maps/place/Mia%C5%82y/@52.8296365,16.2440022,13.29z';
---

<div class="max-w-[73%] border border-[#ccc] rounded-[5px] py-[10px] px-[80px] mx-auto mb-5 bg-white text-base text-center max-[768px]:max-w-[96vw] max-[768px]:p-5 max-[768px]:my-[1px] max-[768px]:mb-5 max-[768px]:text-[0.6rem]">
  {/* Car */}
  <h2 class="text-[24px] text-center mt-5 mb-5 text-brand-black font-bold">{t.carTitle}</h2>
  <div class="text-center mt-2.5 mb-5">
    <a href={carHref} rel="nofollow noopener noreferrer" class="inline-flex items-center text-[18px] text-[#328247] no-underline" target="_blank">
      <Picture alt="Car" height={45} width={45} src="/images/car.png" formats={['avif', 'webp']} class="mr-[5px] align-middle" />
      <span class="leading-none">{t.carBtn}</span>
    </a>
    <p class="text-base leading-[1.6]" set:html={t.carText}></p>
  </div>

  <br />

  {/* Train */}
  <h2 class="text-[24px] text-center mt-5 mb-5 text-brand-black font-bold">{t.trainTitle}</h2>
  <div class="text-center mt-2.5 mb-5">
    <a href={trainHref} rel="nofollow noopener noreferrer" class="inline-flex items-center text-[18px] text-[#328247] no-underline" target="_blank">
      <Picture alt="Train" height={45} width={45} src="/images/train.png" formats={['avif', 'webp']} class="mr-[5px] align-middle" />
      <span class="leading-none">{t.trainBtn}</span>
    </a>
    <p class="text-base leading-[1.6]" set:html={t.trainText}></p>
  </div>

  <br />

  {/* Location */}
  <h2 class="text-[24px] text-center mt-5 mb-5 text-brand-black font-bold">{t.locationTitle}</h2>
  <p class="text-base leading-[1.6]">{t.locationText}</p>
  <div class="text-center mt-2.5">
    <a href={t.mapHref} class="inline-flex items-center text-[18px] text-[#328247] no-underline" target="_blank">
      <Picture alt="Map" height={42} width={42} src="/foto/dojazd-lokalny.png" formats={['avif', 'webp']} class="mr-[5px] align-middle" />
      <span class="leading-none">{t.mapBtn}</span>
    </a>
  </div>

  {/* Map iframe */}
  <section class="w-full mt-[40px] rounded-[5px] text-center text-base bg-white">
    <iframe
      allowfullscreen=""
      height="450"
      loading="lazy"
      src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d9663.21760223439!2d16.3027!3d52.8263!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTLCsDQ5JzM0LjciNiAxNsKwMTgnMDkuNyJF!5e0!3m2!1spl!2spl!4v1682107501701!5m2!1spl!2spl"
      class="border-0 w-full"
      title={t.locationTitle}
      width="100%"
    ></iframe>
  </section>
</div>
