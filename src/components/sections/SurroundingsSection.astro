---
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: 'pl' | 'en' | 'de';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const guideHref = {
  pl: 'https://lasbialas.pl/info/',
  en: '/przewodnik/',
  de: 'https://lasbialas.pl/info/de/',
}[lang];
---

<div class="max-w-[73%] border border-[#ccc] rounded-[5px] py-[10px] px-[80px] mx-auto mb-5 bg-white text-base text-center max-[768px]:max-w-[96vw] max-[768px]:p-5 max-[768px]:my-[1px] max-[768px]:mb-5 max-[768px]:text-[0.6rem]">
  <h2 class="text-[24px] text-center mt-5 mb-5 text-brand-black font-bold">{t('surroundings.title')}</h2>
  <p class="text-base leading-[1.6]" set:html={t('surroundings.text')}></p>
  <div class="flex justify-center mt-[30px]">
    <a class="inline-flex justify-center items-center w-auto h-[46px] text-base font-normal text-white bg-[#e97e2d] border-none text-center no-underline normal-case cursor-pointer mb-[30px] mt-[10px] px-[15px] hover:bg-[#f98847] transition-colors" href={guideHref} target="_blank">{t('nav.guide')}</a>
  </div>
</div>
