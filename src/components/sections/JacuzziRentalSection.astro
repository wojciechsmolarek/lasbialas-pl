---
interface Props {
  lang: 'pl' | 'en' | 'de';
}

const { lang } = Astro.props;

const t = {
  pl: {
    title: 'Wynajem jacuzzi (opcja)',
    intro: 'Wynajem obejmuje <b>nieograniczony dostęp do prywatnego jacuzzi</b>, które znajduje się na tarasie obok domku, w otoczeniu wysokich drzew sosnowego lasu. Ma całodobowo podgrzewaną wodę (stałą temperaturę 37–38\u00a0°C lub inną na życzenie), funkcje aeromasażu, oświetlenie LED, pergolę z regulowanym zadaszeniem i zasłony. W jacuzzi nie stosujemy chloru, woda wymieniana przed każdym pobytem, a w jego trakcie wykonywane są regularne serwisy.',
    colsHeader: ['Długość pobytu', 'Cena jacuzzi za pobyt'],
    colsSub: ['1–2 os.', '3–4 os.'],
    rows: [
      ['2-3 doby', '330 zł', '390 zł'],
      ['4 doby', '430 zł', '510 zł'],
      ['5 dób', '520 zł', '620 zł'],
      ['kolejna doba', '+100 zł', '+120 zł'],
    ],
    feesHeader: ['Opłaty jednorazowe', 'Cena'],
    feesRows: [
      ['Przygotowanie jacuzzi na pobyt', '150 zł'],
    ],
    note: 'Cena wynajmu obejmuje opłatę za przygotowanie (150 zł) oraz opłatę za korzystanie zależną od długości pobytu.',
    petTitle: 'Zasady dotyczące zwierząt',
    petText: 'Z uwagi na charakter obiektu oraz względy organizacyjne, <b>nie przyjmujemy pobytów ze zwierzętami.</b> Uprzejmie prosimy o uwzględnienie tej zasady przy planowaniu rezerwacji.',
  },
  en: {
    title: 'Jacuzzi rental (optional)',
    intro: 'The rental includes unlimited access to a private jacuzzi, which you can enjoy at any time. The jacuzzi is located right next to the cabin, surrounded by tall pine trees. It features 24-hour heated water (37-38°C or adjusted to your preference), air massage functions, LED lighting, a pergola with adjustable roof, and curtains. No chlorine is used - the water is replaced before each stay and maintained regularly during it.',
    colsHeader: ['Length of stay', 'Jacuzzi price per stay'],
    colsSub: ['1–2 guests', '3–4 guests'],
    rows: [
      ['2-3 nights', '330 zł', '390 zł'],
      ['4 nights', '430 zł', '510 zł'],
      ['5 nights', '520 zł', '620 zł'],
      ['additional night', '+100 zł', '+120 zł'],
    ],
    feesHeader: ['One-time fees', 'Price'],
    feesRows: [
      ['Jacuzzi preparation per stay', '150 zł'],
    ],
    note: 'The rental price includes a preparation fee (150 PLN) and a daily usage fee, calculated in the booking system depending on the length of stay.',
    petTitle: 'Pet policy',
    petText: 'Due to the character of the property and organizational reasons, stays with pets are not accepted. Please take this into account when booking.',
  },
  de: {
    title: 'Jacuzzi-Miete (optional)',
    intro: 'Die Miete umfasst uneingeschränkten Zugang zum privaten Jacuzzi, den Sie jederzeit nutzen können. Das Jacuzzi befindet sich direkt neben dem Ferienhaus, umgeben von hohen Kiefern. Er verfügt über dauerhaft beheiztes Wasser (37-38 °C oder auf Wunsch), Luftmassagen, LED-Beleuchtung, eine Pergola mit verstellbarem Dach sowie Vorhänge. Wir verwenden kein Chlor - das Wasser wird vor jedem Aufenthalt gewechselt und regelmäßig gewartet.',
    colsHeader: ['Aufenthaltsdauer', 'Jacuzzi-Preis pro Aufenthalt'],
    colsSub: ['1–2 Pers.', '3–4 Pers.'],
    rows: [
      ['2-3 Nächte', '330 zł', '390 zł'],
      ['4 Nächte', '430 zł', '510 zł'],
      ['5 Nächte', '520 zł', '620 zł'],
      ['weitere Nacht', '+100 zł', '+120 zł'],
    ],
    feesHeader: ['Einmalige Gebühren', 'Preis'],
    feesRows: [
      ['Jacuzzi-Vorbereitung pro Aufenthalt', '150 zł'],
    ],
    note: 'Der Mietpreis beinhaltet die Vorbereitungsgebühr (150 PLN) sowie die tägliche Nutzungsgebühr und wird im Buchungssystem je nach Aufenthaltsdauer berechnet.',
    petTitle: 'Haustierregelung',
    petText: 'Aufgrund der Beschaffenheit des Objekts und organisatorischer Gründe sind Aufenthalte mit Haustieren nicht gestattet. Bitte berücksichtigen Sie dies bei Ihrer Buchung.',
  },
}[lang];
---

<div class="max-w-[73%] border border-[#ccc] rounded-[5px] py-[10px] px-[80px] mx-auto mb-5 bg-white text-base text-center max-[768px]:max-w-[96vw] max-[768px]:p-5 max-[768px]:my-[1px] max-[768px]:mb-5 max-[768px]:text-[0.75rem]">
  <h2 class="text-[24px] max-[768px]:text-[1.1rem] text-center mt-[30px] mb-5 text-brand-black font-bold" id="cennik-jacuzzi">{t.title}</h2>
  <p class="text-base max-[768px]:text-[0.8rem] leading-[1.6]" set:html={t.intro}></p>

  {/* Pricing table */}
  <table class="w-full max-w-[900px] border-collapse text-base max-[768px]:text-[0.8rem] my-[30px] mx-auto bg-[#f4f4f4] border-2 border-white text-center table-fixed max-[768px]:table-auto">
    <thead>
      <tr>
        <th rowspan="2" class="bg-[#362e27] text-white font-semibold px-[6px] py-[4px] h-[40px] border-2 border-white align-middle w-[40%] max-[768px]:w-auto max-[768px]:text-[0.7rem] max-[768px]:leading-[1.2] max-[768px]:break-words max-[768px]:whitespace-normal">{t.colsHeader[0]}</th>
        <th colspan="2" class="bg-[#362e27] text-white font-semibold px-[6px] py-[4px] h-[40px] border-2 border-white align-middle max-[768px]:text-[0.7rem] max-[768px]:leading-[1.2] max-[768px]:break-words max-[768px]:whitespace-normal">{t.colsHeader[1]}</th>
      </tr>
      <tr>
        <th class="bg-[#362e27] text-white font-semibold px-[6px] py-[4px] h-[40px] border-2 border-white align-middle w-[30%] max-[768px]:w-auto max-[768px]:text-[0.7rem] max-[768px]:leading-[1.2]">{t.colsSub[0]}</th>
        <th class="bg-[#362e27] text-white font-semibold px-[6px] py-[4px] h-[40px] border-2 border-white align-middle w-[30%] max-[768px]:w-auto max-[768px]:text-[0.7rem] max-[768px]:leading-[1.2]">{t.colsSub[1]}</th>
      </tr>
    </thead>
    <tbody>
      {t.rows.map((row: string[]) => (
        <tr>
          {row.map((cell: string) => <td class="h-[60px] p-[6px] border-2 border-white align-middle max-[768px]:text-[0.75rem] max-[768px]:h-[48px] max-[768px]:break-words" set:html={cell}></td>)}
        </tr>
      ))}
    </tbody>
  </table>

  {/* Fees table */}
  <table class="w-full max-w-[900px] border-collapse text-base max-[768px]:text-[0.8rem] my-[30px] mx-auto bg-[#f4f4f4] border-2 border-white text-center table-fixed max-[768px]:table-auto">
    <thead>
      <tr>
        {t.feesHeader.map((h: string) => <th class="bg-[#362e27] text-white font-semibold px-[6px] py-[4px] h-[40px] border-2 border-white align-middle max-[768px]:text-[0.7rem] max-[768px]:leading-[1.2] max-[768px]:break-words max-[768px]:whitespace-normal">{h}</th>)}
      </tr>
    </thead>
    <tbody>
      {t.feesRows.map((row: string[]) => (
        <tr>
          {row.map((cell: string) => <td class="h-[60px] p-[6px] border-2 border-white align-middle max-[768px]:text-[0.75rem] max-[768px]:h-[48px] max-[768px]:break-words">{cell}</td>)}
        </tr>
      ))}
    </tbody>
  </table>

  <div class="max-w-[82%] max-[768px]:max-w-[98vw] border border-[#328247] rounded-[5px] p-[5px] my-[5px] mx-auto bg-white text-[1.2rem] max-[768px]:text-[0.8rem] text-[#328247] text-center">
    <p class="my-[5px]">{t.note}</p>
  </div>

  <h3 class="text-[1.3rem] max-[768px]:text-[1rem] text-center mt-[50px] mb-[5px] font-semibold text-[#2c2c2c]">{t.petTitle}</h3>
  <p class="text-base max-[768px]:text-[0.8rem] leading-[1.6]" set:html={t.petText}></p>
</div>
