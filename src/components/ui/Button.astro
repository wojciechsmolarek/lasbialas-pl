---
interface Props {
  variant?: 'reserve' | 'info' | 'dostep';
  href?: string;
  onclick?: string;
  ariaLabel?: string;
  class?: string;
}

const {
  variant = 'reserve',
  href = '#',
  onclick,
  ariaLabel,
  class: className = ''
} = Astro.props;

const variantStyles = {
  reserve: 'bg-primary-green hover:bg-[#40a95c] w-[130px]',
  info: 'bg-primary-green hover:bg-[#40a95c] w-[140px]',
  dostep: 'bg-primary-orange hover:bg-[#c4621a] w-auto px-4'
};

const buttonClass = `
  inline-flex items-center justify-center
  h-[46px] text-base font-normal text-white
  border-0 rounded-[5px] text-center no-underline
  cursor-pointer font-montserrat
  transition-colors duration-200
  ${variantStyles[variant]}
  ${className}
`.trim();
---

<a
  href={href}
  onclick={onclick}
  aria-label={ariaLabel}
  class={buttonClass}
>
  <slot />
</a>
