---
import PageLayout from '../layouts/PageLayout.astro';
const lang = 'pl';
---

<PageLayout
  title="Lokalizacja i dojazd do domków, Las Biala's"
  description="Lokalizacja i dojazd do domków Las Biala's w Białej, Puszcza Notecka. Mapka drogi dojazdu na miejscu."
  lang={lang}
>
  <div class="container mx-auto max-w-5xl px-4 py-8">
    <h1 class="mb-6 text-3xl font-semibold text-center">Dojazd do Las Biala's</h1>
    <img
      src="/foto/droga-dojazdu-do-LB.webp"
      alt="droga dojazdu do domków Las Biala's"
      width="1920"
      height="1125"
      class="w-full h-auto rounded-[5px] cursor-zoom-in"
      id="dojazd-image"
      onclick="openZoom()"
    />
    <p class="text-center text-sm text-gray-500 mt-2">Kliknij obraz, aby przybliżyć</p>
  </div>

  <div id="zoom-overlay" class="fixed inset-0 bg-black/90 z-[9999] hidden items-center justify-center" onclick="closeZoom(event)">
    <img id="zoom-img" src="/foto/droga-dojazdu-do-LB.webp" alt="droga dojazdu do domków Las Biala's" class="max-w-none select-none" style="transform-origin: 0 0; cursor: grab;" />
    <button class="absolute top-4 right-4 text-white text-3xl bg-white/20 hover:bg-white/30 rounded-full w-12 h-12 flex items-center justify-center border-0 cursor-pointer" onclick="closeZoom(event, true)" aria-label="Zamknij">&times;</button>
    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/70 text-sm">Scroll lub pinch, aby przybliżyć &middot; Esc, aby zamknąć</div>
  </div>
</PageLayout>

<script is:inline>
  (function() {
    let scale = 1, x = 0, y = 0;
    let isDragging = false, dragStartX = 0, dragStartY = 0, startX = 0, startY = 0;
    const overlay = document.getElementById('zoom-overlay');
    const img = document.getElementById('zoom-img');

    window.openZoom = function() {
      scale = 1; x = 0; y = 0;
      applyTransform();
      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
    };

    window.closeZoom = function(e, force) {
      if (force || e.target === overlay) {
        overlay.classList.add('hidden');
        overlay.classList.remove('flex');
      }
    };

    function applyTransform() {
      img.style.transform = 'translate(' + x + 'px,' + y + 'px) scale(' + scale + ')';
      img.style.cursor = scale > 1 ? 'grab' : 'zoom-out';
    }

    overlay.addEventListener('wheel', function(e) {
      e.preventDefault();
      const delta = e.deltaY > 0 ? 0.9 : 1.1;
      scale = Math.max(1, Math.min(8, scale * delta));
      if (scale === 1) { x = 0; y = 0; }
      applyTransform();
    }, { passive: false });

    img.addEventListener('touchstart', function(e) {
      if (e.touches.length === 2) {
        startDist = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
        startScale = scale;
      }
    }, { passive: false });

    let startDist = 0, startScale = 1;
    img.addEventListener('touchmove', function(e) {
      if (e.touches.length === 2) {
        e.preventDefault();
        const dist = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
        scale = Math.max(1, Math.min(8, startScale * (dist / startDist)));
        if (scale === 1) { x = 0; y = 0; }
        applyTransform();
      }
    }, { passive: false });

    img.addEventListener('mousedown', function(e) {
      if (scale > 1) {
        isDragging = true;
        dragStartX = e.clientX; dragStartY = e.clientY;
        startX = x; startY = y;
        img.style.cursor = 'grabbing';
      }
    });

    document.addEventListener('mousemove', function(e) {
      if (isDragging) {
        x = startX + (e.clientX - dragStartX);
        y = startY + (e.clientY - dragStartY);
        applyTransform();
      }
    });

    document.addEventListener('mouseup', function() {
      if (isDragging) { isDragging = false; img.style.cursor = 'grab'; }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !overlay.classList.contains('hidden')) {
        closeZoom(e, true);
      }
    });
  })();
</script>
