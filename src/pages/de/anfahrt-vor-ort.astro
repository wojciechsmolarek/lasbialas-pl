---
import PageLayout from '../../layouts/PageLayout.astro';
const lang = 'de';
---

<PageLayout
  title="Anfahrt zu Las Biala's | Biała, Puszcza Notecka"
  description="Anreise zu Las Biala's Ferienhäusern in Biała. Mit Auto, Zug, Karten."
  lang={lang}
>
  <div class="container mx-auto max-w-3xl px-4 py-12">
    <h1 class="mb-8 text-4xl font-semibold">Anfahrt</h1>
    <div class="prose prose-lg">
      <h2>Mit dem Auto</h2>
      <p>Adresse: Biała 32, 64-730 Biała, Polen</p>
      <h2>Mit dem Zug</h2>
      <p>Nächster Bahnhof: Miały (10 km). Transfer verfügbar.</p>
    </div>
  </div>
</PageLayout>
