---
import PageLayout from '../../layouts/PageLayout.astro';
const lang = 'de';
---

<PageLayout
  title="Lage und Anfahrt zu den Ferienhäusern, Las Biala's"
  description="Lage und Anfahrt zu den Ferienhäusern Las Biala's in Biała, Puszcza Notecka. Karte der Anfahrt vor Ort."
  lang={lang}
>
  <div class="container mx-auto max-w-5xl px-4 py-8">
    <h1 class="mb-6 text-3xl font-semibold text-center">Anfahrt zu den Ferienhäusern, Las Biala's</h1>
    <img
      src="/de/foto/anfahrt-vor-ort-LB.webp"
      alt="Anfahrt zu den Ferienhäusern, Las Biala's"
      width="1920"
      height="1125"
      class="w-full h-auto rounded-[5px]"
    />
  </div>
</PageLayout>
