---
import { SEO } from 'astro-seo';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: 'pl' | 'en' | 'de';
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  lang = 'pl',
  canonical,
  ogImage = '/foto/lasbialas8.webp'
} = Astro.props;

const siteUrl = 'https://lasbialas.pl';

// Generate hreflang links
const hreflangs = [
  { lang: 'pl', url: lang === 'pl' ? siteUrl : `${siteUrl}/` },
  { lang: 'en', url: `${siteUrl}/en/` },
  { lang: 'de', url: `${siteUrl}/de/` },
  { lang: 'x-default', url: siteUrl }
];
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="robots" content="noindex, nofollow" />

    <style is:inline>
      @font-face{font-display:optional;font-family:Montserrat;font-style:normal;font-weight:200;src:url(/fonts/Montserrat-Light.woff2) format('woff2')}
      @font-face{font-display:optional;font-family:Montserrat;font-style:normal;font-weight:400;src:url(/fonts/Montserrat-Regular.woff2) format('woff2')}
      @font-face{font-display:optional;font-family:Montserrat;font-style:normal;font-weight:600;src:url(/fonts/Montserrat-SemiBold.woff2) format('woff2')}
    </style>

    <!-- Preload critical fonts (needed for font-display: optional to load in time) -->
    <link rel="preload" href="/fonts/Montserrat-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Montserrat-Light.woff2" as="font" type="font/woff2" crossorigin />

    <!-- DNS prefetch for external domains (lazy-loaded, not critical) -->
    <link rel="dns-prefetch" href="https://cdn.bookero.pl" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://collect.yabrix.com" />

    <SEO
      title={title}
      description={description}
      canonical={canonical || `${siteUrl}${Astro.url.pathname}`}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: `${siteUrl}${ogImage}`,
          url: canonical || `${siteUrl}${Astro.url.pathname}`
        },
        image: {
          width: 1200,
          height: 1200
        }
      }}
    />

    <!-- Hreflang -->
    {hreflangs.map(({ lang: hreflangLang, url }) => (
      <link rel="alternate" hreflang={hreflangLang} href={url} />
    ))}

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />

    <!-- Preload background image used in BannerSection -->
    <link rel="preload" as="image" href="/images/background-image-800.webp" />

    <!-- Preload LCP image (gallery sauna) -->
    <link rel="preload" as="image" href="/foto/webp-834/lasbialas7.webp" fetchpriority="high" />

    <!-- Schema.org Structured Data -->
    <SchemaOrg lang={lang} />

    <!-- Yabrix Analytics (Lazy Load to avoid forced reflow) -->
    <script is:inline>
      (function() {
        function loadYabrix() {
          var s = document.createElement('script');
          s.src = 'https://collect.yabrix.com/js/yabrix.min.js';
          s.setAttribute('data-yx', '1f3667d27b92c8b9');
          s.async = true;
          document.body.appendChild(s);
        }
        window.addEventListener('scroll', loadYabrix, { once: true, passive: true });
        window.addEventListener('mousemove', loadYabrix, { once: true });
        window.addEventListener('touchstart', loadYabrix, { once: true, passive: true });
        setTimeout(loadYabrix, 5000);
      })();
    </script>

    <!-- Google Analytics (Lazy Load) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }

      function loadAnalytics() {
        var script = document.createElement('script');
        script.src = 'https://www.googletagmanager.com/gtag/js?id=G-R3P2XT4WY8';
        script.defer = true;
        document.head.appendChild(script);

        gtag('js', new Date());
        gtag('config', 'G-R3P2XT4WY8', { anonymize_ip: true });
      }

      window.addEventListener('scroll', loadAnalytics, { once: true });
      window.addEventListener('mousemove', loadAnalytics, { once: true });
      window.addEventListener('touchstart', loadAnalytics, { once: true });
    </script>

    <!-- Bookero Reservation System -->
    <script is:inline define:vars={{ lang }}>
      // Bookero configuration
      window.bookero_config = {
        id: 'WmRe79H4lKFz',
        container: 'bookero',
        type: 'sticky',
        position: 'bottom-right',
        plugin_css: true,
        lang: lang
      };

      var bookeroLoaded = false;
      var bookeroPendingClick = false;

      function loadBookeroScript() {
        if (bookeroLoaded) return;
        bookeroLoaded = true;
        var d = document, s = d.createElement('script');
        s.src = 'https://cdn.bookero.pl/plugin/v2/js/bookero-compiled.js';
        s.onload = function() {
          // Hide fallback button once Bookero loads its own toggle
          var fallback = document.getElementById('bookero-sticky-fallback');
          if (fallback) fallback.style.display = 'none';
          if (bookeroPendingClick) {
            bookeroPendingClick = false;
            setTimeout(function() {
              if (typeof window.bookero_open === 'function') {
                window.bookero_open();
              } else {
                var toggle = document.querySelector('.bookero-sticky-plugin-toggle');
                if (toggle) toggle.click();
              }
              // Enforce minimum 3 nights after plugin opens
              if (typeof window.enforceBookeroMinDays === 'function') {
                window.enforceBookeroMinDays();
              }
            }, 200);
          }
        };
        d.body.appendChild(s);
      }

      // Only load on user interaction, not on page load
      window.openReservation = function() {
        if (bookeroLoaded) {
          if (typeof window.bookero_open === 'function') {
            window.bookero_open();
            if (typeof window.enforceBookeroMinDays === 'function') window.enforceBookeroMinDays();
            return;
          }
          if (window.Bookero && window.Bookero.API && typeof window.Bookero.API.openCalendar === 'function') {
            window.Bookero.API.openCalendar();
            if (typeof window.enforceBookeroMinDays === 'function') window.enforceBookeroMinDays();
            return;
          }
          var toggle = document.querySelector('.bookero-sticky-plugin-toggle');
          if (toggle) toggle.click();
          if (typeof window.enforceBookeroMinDays === 'function') window.enforceBookeroMinDays();
        } else {
          bookeroPendingClick = true;
          loadBookeroScript();
        }
      };
    </script>

    <!-- Bookero Validation (Minimum 3 nights) -->
    <script is:inline>
      (function() {
        function enforceMinimumDays() {
          var attempts = 0;
          function tryEnforce() {
            var daysInput = document.getElementById('bookero-plugin-days-number');
            if (daysInput) {
              var days = parseInt(daysInput.value) || 1;
              if (days < 3) {
                daysInput.value = 3;
                var event = new Event('input', { bubbles: true });
                daysInput.dispatchEvent(event);
                var changeEvent = new Event('change', { bubbles: true });
                daysInput.dispatchEvent(changeEvent);
              }
            } else {
              attempts++;
              if (attempts < 20) {
                setTimeout(tryEnforce, 200);
              }
            }
          }
          tryEnforce();
        }

        function initValidation() {
          document.body.addEventListener('bookero-plugin:days-changed', function () {
            enforceMinimumDays();
          });

          document.body.addEventListener('bookero-plugin:service-updated', function () {
            enforceMinimumDays();
          });

          document.body.addEventListener('bookero-plugin:loaded', function () {
            enforceMinimumDays();
          });
        }

        window.enforceBookeroMinDays = enforceMinimumDays;

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initValidation);
        } else {
          initValidation();
        }
      })();
    </script>

    <slot name="head" />
  </head>
  <body class="font-sans font-light">
    <div id="bookero"></div>

    <!-- Sticky reservation button - visible until Bookero loads its own -->
    <button
      id="bookero-sticky-fallback"
      onclick="openReservation()"
      class="fixed bottom-0 right-0 z-[99998] bg-[#2F6940] text-white border-0 cursor-pointer font-montserrat transition-colors hover:bg-[#40a95c]"
    >
      {lang === 'pl' ? 'Rezerwuj' : lang === 'en' ? 'Book Now' : 'Reservieren'}
    </button>
    <style>
      #bookero-sticky-fallback {
        width: 220px;
        height: 56px;
        opacity: 0.96;
        margin-bottom: 3px;
        font-size: large;
        border-radius: 0;
      }
      @media (max-width: 960px) {
        #bookero-sticky-fallback {
          width: 100vw !important;
          max-width: 100vw !important;
          height: 60px !important;
          margin-bottom: 0 !important;
          bottom: 0 !important;
          left: 0 !important;
          right: 0 !important;
          border-radius: 0 !important;
        }
      }
    </style>
    <slot />
  </body>
</html>
