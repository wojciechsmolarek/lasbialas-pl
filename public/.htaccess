<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(woff2|woff|ttf|otf|css|js|webp|svg|jpg|jpeg|png|gif|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

Options -Indexes
DirectorySlash Off

RewriteEngine On
RewriteBase /

# Canonical URL: bez końcowego slasha (poza "/")
RewriteCond %{REQUEST_URI} !^/$
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Canonical URL: bez rozszerzenia .html
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L,NE]

# Strona główna
RewriteRule ^$ index.html [L]

# Clean URLs -> fizyczne pliki .html (również dla ścieżek zagnieżdżonych)
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Przekierowania zewnętrzne na WordPress /info/
RewriteRule ^dojazd/?$ https://lasbialas.pl/info/#/przed-przyjazdem/38 [R=301,L]
RewriteRule ^dojazd\.html$ https://lasbialas.pl/info/#/przed-przyjazdem/38 [R=301,L]
RewriteRule ^en/local-directions/?$ https://lasbialas.pl/info/en/#/before-arrival/1038 [R=301,L]
RewriteRule ^en/local-directions\.html$ https://lasbialas.pl/info/en/#/before-arrival/1038 [R=301,L]
RewriteRule ^de/anfahrt-vor-ort/?$ https://lasbialas.pl/info/de/#/vor-der-anreise/721 [R=301,L]
RewriteRule ^de/anfahrt-vor-ort\.html$ https://lasbialas.pl/info/de/#/vor-der-anreise/721 [R=301,L]

ErrorDocument 404 /404.html
