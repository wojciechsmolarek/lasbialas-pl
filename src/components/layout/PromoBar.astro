---
import { siteConfig } from '../../data/config';

interface Props {
  lang: 'pl' | 'en' | 'de';
}

const { lang } = Astro.props;
const promoBar = siteConfig.promoBar;
const currentMessage = promoBar.messages[lang] ?? '';
---

{
  promoBar.enabled && currentMessage && (
    <div class="w-full bg-[#E97E2D] py-[10px] px-[15px] text-brand-black text-center text-[15px] relative z-[3000]">
      <Fragment set:html={currentMessage} />
    </div>
  )
}
