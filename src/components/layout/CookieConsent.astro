---
interface Props {
  lang: 'pl' | 'en' | 'de';
}

const { lang } = Astro.props;

// Tłumaczenia dla cookies - styl talem.eu
const translations = {
  pl: {
    title: 'Używamy plików cookie',
    description: 'Ta strona wykorzystuje pliki cookie w celu zapewnienia najlepszego doświadczenia użytkownika oraz analizy ruchu.',
    acceptAll: 'Zaakceptuj wszystkie',
    necessaryOnly: 'Tylko niezbędne',
    managePreferences: 'Zarządzaj preferencjami',
    privacy: 'Polityka prywatności',
    preferencesTitle: 'Zarządzaj preferencjami plików cookie',
    necessary: 'Niezbędne',
    analytics: 'Analityczne',
    marketing: 'Marketingowe',
    necessaryDesc: 'Wymagane do działania strony',
    analyticsDesc: 'Pomagają nam zrozumieć, jak korzystasz ze strony',
    marketingDesc: 'Używane do wyświetlania spersonalizowanych reklam',
    savePreferences: 'Zapisz preferencje'
  },
  en: {
    title: 'We use cookies',
    description: 'This website uses cookies to ensure the best user experience and traffic analysis.',
    acceptAll: 'Accept all',
    necessaryOnly: 'Only necessary',
    managePreferences: 'Manage preferences',
    privacy: 'Privacy Policy',
    preferencesTitle: 'Manage cookie preferences',
    necessary: 'Necessary',
    analytics: 'Analytics',
    marketing: 'Marketing',
    necessaryDesc: 'Required for the website to function',
    analyticsDesc: 'Help us understand how you use the site',
    marketingDesc: 'Used to display personalized ads',
    savePreferences: 'Save preferences'
  },
  de: {
    title: 'Wir verwenden Cookies',
    description: 'Diese Webseite verwendet Cookies, um die beste Benutzererfahrung und Traffic-Analyse zu gewährleisten.',
    acceptAll: 'Alle akzeptieren',
    necessaryOnly: 'Nur notwendige',
    managePreferences: 'Präferenzen verwalten',
    privacy: 'Datenschutzerklärung',
    preferencesTitle: 'Cookie-Präferenzen verwalten',
    necessary: 'Notwendig',
    analytics: 'Analytisch',
    marketing: 'Marketing',
    necessaryDesc: 'Erforderlich für die Funktionsweise der Website',
    analyticsDesc: 'Helfen uns zu verstehen, wie Sie die Seite nutzen',
    marketingDesc: 'Werden für personalisierte Anzeigen verwendet',
    savePreferences: 'Präferenzen speichern'
  }
};

const t = translations[lang];
---

<!-- Mały dymek cookies na dole po lewej -->
<div id="cookie-banner" class="fixed bottom-4 left-4 bg-white text-gray-800 p-4 rounded-lg shadow-lg z-[9999] transform translate-y-full transition-all duration-300 max-w-sm">
  <div class="mb-3">
    <h4 class="font-semibold text-sm mb-1">{t.title}</h4>
    <p class="text-xs text-gray-600 leading-relaxed">{t.description}</p>
  </div>
  
  <div class="flex flex-col gap-2">
    <button 
      id="cookie-accept-all"
      class="w-full px-3 py-2 text-xs bg-brand-green text-white rounded hover:bg-[#2F6940] transition-colors font-medium"
    >
      {t.acceptAll}
    </button>
    <button 
      id="cookie-necessary-only"
      class="w-full px-3 py-2 text-xs bg-gray-200 text-gray-800 rounded hover:bg-gray-300 transition-colors"
    >
      {t.necessaryOnly}
    </button>
    <button 
      id="cookie-manage-preferences"
      class="w-full px-3 py-2 text-xs text-brand-green hover:text-[#2F6940] transition-colors underline"
    >
      {t.managePreferences}
    </button>
  </div>
</div>

<!-- Modalne okno zarządzania preferencjami -->
<div id="cookie-preferences-modal" class="fixed inset-0 bg-black bg-opacity-50 z-[10000] hidden flex items-center justify-center p-4">
  <div class="bg-white rounded-lg max-w-md w-full max-h-[90vh] overflow-y-auto">
    <div class="p-6">
      <div class="flex justify-between items-center mb-4">
        <h3 class="text-lg font-semibold">{t.preferencesTitle}</h3>
        <button id="close-modal" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
      </div>
      
      <div class="space-y-4 mb-6">
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <label class="font-medium text-sm">{t.necessary}</label>
            <p class="text-xs text-gray-600 mt-1">{t.necessaryDesc}</p>
          </div>
          <input type="checkbox" id="necessary-cookies" checked disabled class="w-4 h-4 text-brand-green rounded">
        </div>
        
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <label class="font-medium text-sm">{t.analytics}</label>
            <p class="text-xs text-gray-600 mt-1">{t.analyticsDesc}</p>
          </div>
          <input type="checkbox" id="analytics-cookies" class="w-4 h-4 text-brand-green rounded">
        </div>
        
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <label class="font-medium text-sm">{t.marketing}</label>
            <p class="text-xs text-gray-600 mt-1">{t.marketingDesc}</p>
          </div>
          <input type="checkbox" id="marketing-cookies" class="w-4 h-4 text-brand-green rounded">
        </div>
      </div>
      
      <div class="flex gap-2">
        <button 
          id="save-preferences"
          class="flex-1 px-4 py-2 text-sm bg-brand-green text-white rounded hover:bg-[#2F6940] transition-colors"
        >
          {t.savePreferences}
        </button>
        <a 
          href={lang === 'pl' ? '/polityka-prywatnosci' : lang === 'en' ? '/en/privacy-policy' : '/de/datenschutzerklarung'}
          class="flex-1 px-4 py-2 text-sm text-center text-gray-600 hover:text-gray-800 underline transition-colors"
        >
          {t.privacy}
        </a>
      </div>
    </div>
  </div>
</div>

<script is:inline defer>
  // Cookie Consent Functionality - styl talem.eu
  (function() {
    const cookieName = 'cc_cookies';
    const banner = document.getElementById('cookie-banner');
    const modal = document.getElementById('cookie-preferences-modal');
    const acceptAllBtn = document.getElementById('cookie-accept-all');
    const necessaryOnlyBtn = document.getElementById('cookie-necessary-only');
    const managePreferencesBtn = document.getElementById('cookie-manage-preferences');
    const closeModalBtn = document.getElementById('close-modal');
    const savePreferencesBtn = document.getElementById('save-preferences');
    const analyticsCheckbox = document.getElementById('analytics-cookies');
    const marketingCheckbox = document.getElementById('marketing-cookies');

    // Check if consent already given
    if (document.cookie.includes(cookieName + '=')) {
      return; // Don't show banner if consent already given
    }

    // Show banner after delay
    setTimeout(() => {
      if (banner) {
        banner.style.transform = 'translateY(0)';
      }
    }, 1000);

    // Set cookie function
    function setCookie(value, days = 365) {
      const date = new Date();
      date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
      const expires = 'expires=' + date.toUTCString();
      document.cookie = cookieName + '=' + value + ';' + expires + ';path=/;SameSite=Lax';
    }

    // Hide banner function
    function hideBanner() {
      if (banner) {
        banner.style.transform = 'translateY(100%)';
        setTimeout(() => {
          banner.style.display = 'none';
        }, 300);
      }
    }

    // Show modal
    function showModal() {
      if (modal) {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      }
    }

    // Hide modal
    function hideModal() {
      if (modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
    }

    // Update Google Analytics consent
    function updateAnalyticsConsent(allowed) {
      if (typeof gtag !== 'undefined') {
        gtag('consent', 'update', {
          'analytics_storage': allowed ? 'granted' : 'denied'
        });
      }
    }

    // Accept all cookies
    if (acceptAllBtn) {
      acceptAllBtn.addEventListener('click', function() {
        setCookie('all');
        hideBanner();
        updateAnalyticsConsent(true);
      });
    }

    // Accept only necessary cookies
    if (necessaryOnlyBtn) {
      necessaryOnlyBtn.addEventListener('click', function() {
        setCookie('necessary');
        hideBanner();
        updateAnalyticsConsent(false);
      });
    }

    // Show preferences modal
    if (managePreferencesBtn) {
      managePreferencesBtn.addEventListener('click', function() {
        showModal();
      });
    }

    // Close modal
    if (closeModalBtn) {
      closeModalBtn.addEventListener('click', hideModal);
    }

    // Click outside modal to close
    if (modal) {
      modal.addEventListener('click', function(e) {
        if (e.target === modal) {
          hideModal();
        }
      });
    }

    // Save preferences
    if (savePreferencesBtn) {
      savePreferencesBtn.addEventListener('click', function() {
        const analyticsEnabled = analyticsCheckbox.checked;
        const marketingEnabled = marketingCheckbox.checked;
        
        let consentValue = 'necessary';
        if (analyticsEnabled && marketingEnabled) {
          consentValue = 'all';
        } else if (analyticsEnabled) {
          consentValue = 'analytics';
        }
        
        setCookie(consentValue);
        hideBanner();
        hideModal();
        updateAnalyticsConsent(analyticsEnabled);
      });
    }
  })();
</script>
