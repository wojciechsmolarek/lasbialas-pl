---
import { Picture } from 'astro:assets';
import lasBialasWww from '../../assets/images/las-bialas-www.png';
import bookingLogo from '../../assets/images/booking_logo.webp';
import airbnbLogo from '../../assets/images/airbnb_logo.webp';
import alohaLogo from '../../assets/images/aloha_logo.webp';
---

<section class="w-full bg-[#f2f2f2] p-5 mb-5">
  <div class="grid grid-cols-[repeat(4,auto)] justify-center justify-items-center items-center gap-[120px] max-w-[1280px] mx-auto max-[1023px]:grid-cols-[repeat(2,auto)] max-[1023px]:gap-x-0 max-[1023px]:gap-y-[15px]">
    <a href="#" aria-label="Otwórz panel rezerwacji" onclick="openReservation(); return false;" class="inline-block items-center">
      <Picture alt="Las Biala's" src={lasBialasWww} width={163} height={30} formats={['avif', 'webp']} loading="lazy" decoding="async" class="block w-[163px] h-[30px] max-[1023px]:p-2" />
    </a>
    <div class="text-center">
      <a href="https://www.booking.com/hotel/pl/las-bialas-kameralne-domki-w-puszczy-noteckiej.pl.html" target="_blank" rel="nofollow noopener noreferrer" aria-label="Booking.com">
        <Picture alt="booking.com" src={bookingLogo} width={172} height={40} formats={['avif', 'webp']} loading="lazy" decoding="async" class="block w-[172px] h-[40px] mt-2.5 max-[1023px]:p-2" />
      </a>
    </div>
    <div class="text-center">
      <a href="https://www.airbnb.pl/h/lasbialas1" target="_blank" rel="nofollow noopener noreferrer" aria-label="Airbnb">
        <Picture alt="airbnb" src={airbnbLogo} width={194} height={45} formats={['avif', 'webp']} loading="lazy" decoding="async" class="block w-[194px] h-[45px] mt-2.5 max-[1023px]:p-2" />
      </a>
    </div>
    <div class="text-center">
      <a href="https://r.alohacamp.com/c0zx" target="_blank" rel="nofollow noopener noreferrer" aria-label="Alohacamp">
        <Picture alt="alohacamp" src={alohaLogo} width={190} height={44} formats={['avif', 'webp']} loading="lazy" decoding="async" class="block w-[190px] h-[44px] mt-2.5 max-[1023px]:p-2" />
      </a>
    </div>
  </div>
</section>
