---
import PageLayout from '../../layouts/PageLayout.astro';
const lang = 'en';
---

<PageLayout
  title="Location & Directions to Las Biala's Cottages"
  description="Access map to Las Biala's cottages in the village of Biała in the Noteć Forest."
  lang={lang}
>
  <div class="container mx-auto max-w-5xl px-4 py-8">
    <h1 class="mb-6 text-3xl font-semibold text-center">Access map to Las Biala's cottages</h1>
    <img
      src="/en/foto/local-directions.webp"
      alt="Location & Directions to Las Biala's Cottages"
      width="1920"
      height="1125"
      class="w-full h-auto rounded-[5px]"
    />
  </div>
</PageLayout>
