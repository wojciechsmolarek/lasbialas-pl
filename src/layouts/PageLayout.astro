---
import BaseLayout from './BaseLayout.astro';
import PromoBar from '../components/layout/PromoBar.astro';
import TopBar from '../components/layout/TopBar.astro';
import Footer from '../components/layout/Footer.astro';
import CookieConsent from '../components/layout/CookieConsent.astro';
import GalleryOverlay from '../components/sections/GalleryOverlay.astro';

interface Props {
  title: string;
  description: string;
  lang?: 'pl' | 'en' | 'de';
  canonical?: string;
  ogImage?: string;
  isHomePage?: boolean;
}

const { title, description, lang = 'pl', canonical, ogImage, isHomePage = false } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  canonical={canonical}
  ogImage={ogImage}
>
  <slot name="head" slot="head" />

  <PromoBar lang={lang} />
  <TopBar lang={lang} isHomePage={isHomePage} />

  <main>
    <slot />
  </main>

  <Footer lang={lang} />
  <CookieConsent lang={lang} />
  <GalleryOverlay />
</BaseLayout>
