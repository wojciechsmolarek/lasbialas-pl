---
import PageLayout from '../../layouts/PageLayout.astro';
const lang = 'de';
---

<PageLayout
  title="404 - Seite nicht gefunden | Las Biala's"
  description="Die gesuchte Seite wurde nicht gefunden."
  lang={lang}
>
  <div class="container mx-auto max-w-3xl px-4 py-24 text-center">
    <h1 class="mb-4 text-9xl font-bold">404</h1>
    <h2 class="mb-8 text-3xl font-semibold">Seite nicht gefunden</h2>
    <p class="mb-8 text-lg">Entschuldigung, die gesuchte Seite existiert nicht.</p>
    <a href="/de/" class="inline-block bg-primary-green px-6 py-3 text-white hover:bg-green-700">
      Zur Startseite zurückkehren
    </a>
  </div>
</PageLayout>
