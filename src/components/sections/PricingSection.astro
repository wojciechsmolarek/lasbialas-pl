---
interface Props {
  lang: 'pl' | 'en' | 'de';
}

const { lang } = Astro.props;

const t = {
  pl: {
    title: 'Cennik 2026',
    cols: ['cena za dobę*', 'długość pobytu', '3-4 osoby'],
    rows: [
      ['<strong>475 zł *</strong>', 'od 4 dób', '+120 zł / os.'],
      ['495 zł *', '3 doby', '+120 zł / os.'],
      ['525 zł', '2 doby', '+120 zł / os.'],
    ],
    notes: [
      '<b>* Minimalny okres pobytu: 2 doby</b>',
      '<b>*</b> rabat naliczany automatycznie w systemie rezerwacji',
    ],
    amenitiesCols: ['cena za dobę', 'liczba osób'],
    amenitiesRows: [
      ['550 zł', '1-2 osoby'],
      ['625 zł', '3 osoby'],
      ['745 zł', '4 osoby'],
    ],
    reserve: 'Rezerwuj',
    freeTitle: 'Bezpłatnie dla Gości',
    freeItems: ['sauna', 'balia z wodą do schładzania', 'szlafroki i ręczniki do saunowania', '4 rowery trekkingowe', 'grill', 'węgiel, podpałka do grilla', '4 deski SUP (od V do X)'],
    dayInfo: 'Doba pobytu trwa od 16:00 do 12:00 (poza sezonem letnim możliwość ustalenia innych godzin). Nie pobieramy opłat licznikowych. Wystawiamy fakturę VAT. Więcej szczegółów dotyczących wyposażenia, udogodnień i pobytu na miejscu znajdziesz w naszym <a href="{#guide}" target="_blank" class="text-[#328247] no-underline hover:underline">przewodniku</a>.',
    benefits: ['najkorzystniejsze ceny', 'pobyty już od 2 nocy', 'rabaty na pobyty 3+ dobowe', 'opcja innej pory (za/wy)meldowania', 'możliwość zmiany terminu'],
    footerText: 'Szczegółowy cennik oraz zasady korzystania z domków znajdziecie Państwo w <b><a href="{#guide}" target="_blank" class="text-brand-dark-green">przewodniku dla Gości</a></b>',
    guideBtn: 'Przewodnik',
  },
  en: {
    title: 'Pricing 2026',
    cols: ['length', 'price per night', '3-4 guests'],
    rows: [
      ['2 nights', '550 zł', '+120 zł / guest'],
      ['3 nights', '520 zł*', '+120 zł / guest'],
      ['4+ nights', '495 zł*', '+120 zł / guest'],
    ],
    notes: [
      '<b>* Minimum stay: 2 nights</b>',
      '<b>*</b> Discount is applied automatically in the booking system',
    ],
    amenitiesCols: ['price per night', 'number of guests'],
    amenitiesRows: [
      ['550 zł', '1-2 guests'],
      ['625 zł', '3 guests'],
      ['745 zł', '4 guests'],
    ],
    reserve: 'Book Now',
    freeTitle: 'Free for Guests',
    freeItems: ['sauna', 'cooling water tub', 'bathrobes and sauna towels', '4 trekking bikes', 'portable grill', 'charcoal, fire starter, and grill accessories', '4 SUP boards (from May to October)'],
    dayInfo: 'The stay lasts from 4:00 PM to 12:00 PM (other times can be arranged). No utility fees. VAT invoice available. More details about the equipment, amenities, and your stay can be found in our <a href="{#guide}" target="_blank" class="text-[#328247] no-underline hover:underline">guide</a>.',
    benefits: ['best prices', 'stays from 2 nights', 'flexible check-in/out times', '5% off your next stay', 'option to change dates', 'discount for 3+ night stays'],
    footerText: 'Detailed pricing and cottage rules can be found in the <b><a href="{#guide}" target="_blank" class="text-brand-dark-green">Guest Guidebook</a></b>',
    guideBtn: 'Guide',
  },
  de: {
    title: 'Preise 2026',
    cols: ['Aufenthaltsdauer', 'Preis pro Nacht', '3-4 Pers.'],
    rows: [
      ['2 Nächte', '550 zł', '+120 zł / Pers.'],
      ['3 Nächte', '520 zł*', '+120 zł / Pers.'],
      ['ab 4 Nächten', '495 zł*', '+120 zł / Pers.'],
    ],
    notes: [
      '<b>* Mindestaufenthalt: 2 Nächte</b>',
      '<b>*</b> Der Rabatt wird automatisch im Buchungssystem angewendet',
    ],
    amenitiesCols: ['Preis pro Nacht', 'Anzahl der Personen'],
    amenitiesRows: [
      ['550 zł', '1-2 Pers.'],
      ['625 zł', '3 Pers.'],
      ['745 zł', '4 Pers.'],
    ],
    reserve: 'Reservierung',
    freeTitle: 'Kostenlos für Gäste',
    freeItems: ['Sauna', 'Abkühlbottich mit Wasser', 'Bademäntel und Saunatücher', '4 Trekking-Fahrräder', 'tragbarer Grill', 'Kohle, Anzünder und Grillzubehör', '4 SUP-Boards (von Mai bis Oktober)'],
    dayInfo: 'Der Aufenthalt dauert von 16:00 bis 12:00 (andere Zeiten nach Absprache möglich). Es fallen keine Zählergebühren an. Wir stellen eine Rechnung mit MwSt. aus. Weitere Details zur Ausstattung, zu den Annehmlichkeiten und zum Aufenthalt findest du in unserem <a href="{#guide}" target="_blank" class="text-[#328247] no-underline hover:underline">Leitfaden</a>.',
    benefits: ['die besten Preise', 'Aufenthalte ab 2 Nächten', 'flexible Check-in/out-Zeiten', '5 % auf den nächsten Aufenthalt', 'Möglichkeit zur Terminänderung', 'Rabatt für Aufenthalte ab 3 Nächten'],
    footerText: 'Detaillierte Preise und Hausregeln finden Sie im <b><a href="{#guide}" target="_blank" class="text-brand-dark-green">Gästeführer</a></b>',
    guideBtn: 'Reiseführer',
  },
}[lang];

const guideHref = {
  pl: 'https://lasbialas.pl/info/',
  en: '/przewodnik/',
  de: 'https://info.lasbialas.pl/de/',
}[lang];

const colW = ['w-[40%] max-[768px]:w-[20%]', 'w-[30%] max-[768px]:w-[26.66%]', 'w-[30%] max-[768px]:w-[26.66%]'];

const tableClass = 'w-full max-w-[900px] border-collapse overflow-hidden text-base my-[30px] mx-auto bg-[#f4f4f4] border-2 border-white text-center table-fixed';
const thClass = 'bg-[#362e27] text-white font-semibold px-[6px] py-[4px] h-[40px] border-2 border-white align-middle';
const tdClass = 'h-[60px] p-[6px] border-2 border-white align-middle max-[768px]:text-[0.95rem]';
---

<div class="max-w-[73%] border border-[#ccc] rounded-[5px] py-[10px] px-[80px] mx-auto mb-5 bg-white text-base text-center max-[768px]:max-w-[96vw] max-[768px]:p-5 max-[768px]:my-[1px] max-[768px]:mb-5 max-[768px]:text-[0.6rem]">
  <h2 class="text-[24px] text-center mt-5 mb-5 text-brand-black font-bold">{t.title}</h2>

  {/* Main pricing table */}
  <table class={tableClass}>
    <thead>
      <tr>
        {t.cols.map((col: string, i: number) => (
          <th class={`${thClass} ${colW[i] || ''}`} set:html={col}></th>
        ))}
      </tr>
    </thead>
    <tbody>
      {t.rows.map((row: string[]) => (
        <tr>
          {row.map((cell: string) => (
            <td class={tdClass} set:html={cell}></td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>

  {/* Notes */}
  <div class="max-w-[82%] max-[768px]:max-w-[98vw] border border-[#328247] rounded-[5px] p-[5px] my-[5px] mx-auto bg-white text-[1.2rem] text-[#328247] text-center">
    {t.notes.map((note: string) => (
      <p class="my-[5px]" set:html={note}></p>
    ))}
  </div>

  {/* Amenities table */}
  <table class={tableClass}>
    <thead>
      <tr>
        {t.amenitiesCols.map((col: string, i: number) => (
          <th class={`${thClass} ${colW[i] || ''}`}>{col}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {t.amenitiesRows.map((row: string[]) => (
        <tr>
          {row.map((cell: string) => (
            <td class={tdClass} set:html={cell}></td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>

  {/* Reserve button */}
  <div class="flex justify-center mt-[30px]">
    <a aria-label="Otwórz panel rezerwacji" class="flex justify-center items-center w-[140px] h-[46px] text-base font-normal text-white bg-[#2F6940] border-none text-center no-underline normal-case cursor-pointer font-montserrat mb-[30px] hover:bg-[#40a95c] transition-colors" href="#" onclick="openReservation(); return false;">{t.reserve}</a>
  </div>

  {/* Free items */}
  <h3 class="text-[1.3rem] text-center mt-[40px] mb-[5px] font-semibold text-[#2c2c2c]">{t.freeTitle}</h3>
  <div class="text-base leading-[1.6] text-brand-black">
    <ul class="flex flex-wrap justify-center gap-y-[6px] gap-x-[16px] my-2.5 p-0 list-none">
      {t.freeItems.map((item: string) => (
        <li class="m-0 leading-[1.4] text-[0.9rem] flex items-center">
          <span class="inline-block w-[0.45rem] h-[0.45rem] bg-[#2F6940] mr-[.5em] shrink-0"></span>{item}
        </li>
      ))}
    </ul>
  </div>

  {/* Day info & footer */}
  <p class="text-base leading-[1.6]" set:html={t.dayInfo.replace('{#guide}', guideHref)}></p>

  {/* Benefits */}
  <ul class="flex flex-wrap justify-center gap-y-[6px] gap-x-[16px] my-[20px] p-0 list-none">
    {t.benefits.map((item: string) => (
      <li class="m-0 leading-[1.4] text-[0.9rem] flex items-center">
        <span class="inline-block w-[0.45rem] h-[0.45rem] bg-[#2F6940] mr-[.5em] shrink-0"></span>{item}
      </li>
    ))}
  </ul>

  <div class="flex justify-center mt-[30px]">
    <a class="inline-flex justify-center items-center w-auto h-[46px] text-base font-normal text-white bg-[#2F6940] border-none text-center no-underline normal-case cursor-pointer mb-[30px] mt-[10px] px-[15px] hover:bg-[#40a95c] transition-colors" href={guideHref} target="_blank">{t.guideBtn}</a>
  </div>
</div>
