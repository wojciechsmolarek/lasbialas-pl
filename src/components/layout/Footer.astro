---
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: 'pl' | 'en' | 'de';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// URLs for different pages
const blogUrl = 'https://lasbialas.pl/blog/';
const guideUrl = 'https://lasbialas.pl/info/';

// Localized internal links
const termsPath = lang === 'pl' ? '/regulamin' : lang === 'en' ? '/en/terms-and-conditions' : '/de/hausordnung';
const privacyPath = lang === 'pl' ? '/polityka-prywatnosci' : lang === 'en' ? '/en/privacy-policy' : '/de/datenschutzerklarung';
const gdprPath = lang === 'pl' ? '/rodo' : lang === 'en' ? '/en/rodo' : '/de/rodo';
---

<div class="bg-[#323131] text-white text-base font-normal [text-shadow:0px_0px_1px_rgba(0,0,0,0.2),0px_-1px_1px_rgba(0,0,0,0.1)] relative bottom-0 left-0 w-full mt-5 py-[18px] px-[19px] max-[1024px]:mb-[80px]">
  <div class="flex justify-between items-center flex-wrap gap-2 w-full max-w-[1024px] mx-auto max-[768px]:flex-col max-[768px]:items-center max-[768px]:text-center">
    <p class="m-0 max-[768px]:mt-2.5 max-[768px]:mb-0">© <span id="year"></span> Las Biala's</p>

    <div class="flex gap-3 flex-wrap justify-center max-[768px]:flex-col max-[768px]:gap-1.5 max-[768px]:mt-2.5">
      <a href={blogUrl} target="_blank" rel="noopener noreferrer" class="text-white no-underline hover:underline">{t('nav.blog')}</a>
      <a href={guideUrl} target="_blank" rel="noopener noreferrer" class="text-white no-underline hover:underline">{t('nav.guide')}</a>
      <a href={termsPath} class="text-white no-underline hover:underline">{t('nav.terms')}</a>
      <a href={privacyPath} class="text-white no-underline hover:underline">{t('nav.privacy')}</a>
      <a href={gdprPath} class="text-white no-underline hover:underline">{t('nav.gdpr')}</a>
    </div>
  </div>
</div>

<script is:inline>
  // Skrypt do dynamicznego ustawienia roku
  document.getElementById('year').innerText = new Date().getFullYear();
</script>
