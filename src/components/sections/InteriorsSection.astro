      ],
    },
    bathroom: {
      title: 'Łazienka',
      intro: 'Nowoczesna łazienka z prysznicem walk-in i deszczownicą. Na wyposażeniu:',
      items: ['komplet ręczników', 'żel i szampon pod prysznic', 'mydło w płynie', 'środki czystości', 'papier toaletowy', 'suszarka do włosów', 'odkurzacz bezprzewodowy', 'suszarka na pranie', 'inne akcesoria'],
      images: [
        { src: w17, alt: 'Łazienka z prysznicem', tip: 'Przestronna łazienka z prysznicem walk-in.' },
        { src: w18, alt: 'Wyposażenie łazienki', tip: 'Ręczniki, środki higieniczne i akcesoria.' },
      ],
    },
    parking: {
      title: 'Bezpłatny parking',
      text: 'Przy każdym z domków dostępne są dwa miejsca parkingowe. Teren ogrodzony i oświetlony, osobna brama i furtka.',
    },
    guide: {
      title: 'Przewodnik LAS BIALA\'S',
      qrAlt: 'QR kod do przewodnika LAS BIALA\'S',
    },
  },
  en: {
    title: 'Comfortable Interiors & Full Equipment',
    intro: 'The cottages are equipped with a range of amenities, full furnishings, and cozy interiors to make your stay comfortable while enjoying the charm and unique atmosphere of this place.',
    bedrooms: {
      title: 'Bedrooms',
      intro: 'The cottages feature two bedrooms located on opposite sides of the house. Bedroom amenities include:',
      items: ['comfortable double beds', 'mattresses 140x200x26 cm', 'cotton bedding', 'mosquito nets in windows', 'ceiling fan with remote control', 'external blinds and curtains', 'Smart TV with Netflix in one bedroom'],
      images: [
        { src: w1, alt: 'Large bedroom with double bed', tip: 'Large bedroom with 140x200 bed, comfortable mattress and ceiling fan.' },
        { src: w2, alt: 'Small bedroom with double bed', tip: 'Small bedroom with 140x200 bed and Smart TV.' },
        { src: w6, alt: 'Heating in the cottage', tip: 'Independent thermostats controlling heating in each room.' },
        { src: w4, alt: 'Small bedroom in the cottage', tip: 'Bedroom with 140x200 bed, Smart TV and ceiling fan.' },
      ],
    },
    living: {
      title: 'Living Room with Kitchenette',
      intro: 'The living room with kitchenette offers a cozy lounge area, Smart TV with Netflix, bookshelf, and board games. The <a href="{#guide}" target="_blank" class="text-brand-green underline">kitchenette</a> is fully equipped and includes a large fridge, dishwasher, toaster, coffee machine, and induction hob - everything you need for comfortable cooking and dining:',
      items: ['set of pots and pans', 'sets of plates (6 pcs) and bowls', 'mugs, glasses, wine glasses, and more', 'full set of cutlery and kitchen knives', 'kitchen and barbecue accessories', 'toaster, kettle, tea infuser', 'Nespresso DeLonghi coffee machine', '20 coffee capsules', 'tea, sugar, salt, pepper'],
      images: [
        { src: w13, alt: 'Living room with kitchenette', tip: 'Spacious living room with kitchenette.' },
        { src: w7, alt: 'Kitchenette', tip: 'Kitchenette with fridge, dishwasher and induction hob.' },
        { src: w15, alt: 'Lounge corner in living room', tip: 'Bookshelf and board games.' },
        { src: w3, alt: 'Smart TV in living room', tip: 'Smart TV with Netflix.' },
      ],
    },
    bathroom: {
      title: 'Bathroom',
      intro: 'A modern bathroom with walk-in shower and rainfall showerhead. Amenities include:',
      items: ['set of towels', 'shower gel & shampoo', 'liquid soap', 'cleaning products', 'toilet paper', 'hair dryer', 'cordless vacuum cleaner', 'drying rack', 'other accessories'],
      images: [
        { src: w17, alt: 'Bathroom with shower', tip: 'Spacious bathroom with walk-in shower.' },
        { src: w18, alt: 'Bathroom amenities', tip: 'Towels, hygiene products and accessories.' },
      ],
    },
    parking: {
      title: 'Free Parking',
      text: 'Each cottage has two parking spaces. The area is fenced and illuminated, with a separate gate and entrance.',
    },
    guide: {
      title: 'Guidebook LAS BIALA\'S',
      qrAlt: 'QR code to LAS BIALA\'S guidebook',
    },
  },
  de: {
    title: 'Komfortable Innenräume und komplette Ausstattung',
    intro: 'In den Häusern haben wir zahlreiche Annehmlichkeiten, eine vollständige Ausstattung und gemütliche Innenräume vorbereitet, damit Sie Ihren Aufenthalt komfortabel verbringen und die besondere Atmosphäre des Ortes genießen können.',
    bedrooms: {
      title: 'Schlafzimmer',
      intro: 'Die Häuser verfügen über zwei Schlafzimmer, die sich an gegenüberliegenden Seiten des Hauses befinden. Schlafzimmer-Ausstattung:',
      items: ['bequeme Doppelbetten', 'Matratzen 140×200×26 cm', 'Baumwollbettwäsche', 'Insektenschutzgitter an den Fenstern', 'Deckenventilator mit Fernbedienung', 'Außenrollläden und Vorhänge', 'Smart TV (Netflix) im Schlafzimmer'],
      images: [
        { src: w1, alt: 'Großes Schlafzimmer mit Doppelbett', tip: 'Großes Schlafzimmer mit Bett 140x200, bequemer Matratze und Deckenventilator.' },
        { src: w2, alt: 'Kleines Schlafzimmer mit Doppelbett', tip: 'Kleines Schlafzimmer mit Bett 140x200 und Smart TV.' },
        { src: w6, alt: 'Heizung im Haus', tip: 'Unabhängige Thermostate steuern die Heizung in jedem Raum.' },
        { src: w4, alt: 'Kleines Schlafzimmer im Haus', tip: 'Schlafzimmer mit Bett 140x200, Smart TV und Deckenventilator.' },
      ],
    },
    living: {
      title: 'Wohnzimmer mit Küchenzeile',
      intro: 'Im Wohnzimmer mit Küchenzeile gibt es eine gemütliche Sitzecke, einen Smart TV mit Netflix, eine kleine Bibliothek und Brettspiele. Die <a href="{#guide}" target="_blank" class="text-brand-green underline">Küchenzeile</a> ist komplett ausgestattet und bietet einen großen Kühlschrank, eine Spülmaschine, Toaster, Kaffeemaschine sowie ein Induktionskochfeld - alles, was Sie zum bequemen Kochen und gemeinsamen Essen benötigen:',
      items: ['Topf- und Pfannenset', 'Sets mit Tellern (je 6 Stk.) und Schalen', 'Tassen, Gläser, Weingläser u.a.', 'Besteck- und Kochmesserset', 'Küchen- und Grillzubehör', 'Toaster, Wasserkocher, Teezubereiter', 'Nespresso DeLonghi Kaffeemaschine', 'Kaffeekapseln (20 Stk.)', 'Tee, Zucker, Salz, Pfeffer'],
      images: [
        { src: w13, alt: 'Wohnzimmer mit Küchenzeile', tip: 'Geräumiges Wohnzimmer mit Küchenzeile.' },
        { src: w7, alt: 'Küchenzeile', tip: 'Küchenzeile mit Kühlschrank, Spülmaschine und Induktionskochfeld.' },
        { src: w15, alt: 'Sitzecke im Wohnzimmer', tip: 'Bibliothek und Brettspiele.' },
        { src: w3, alt: 'Smart TV im Wohnzimmer', tip: 'Smart TV mit Netflix.' },
      ],
    },
    bathroom: {
      title: 'Badezimmer',
      intro: 'Modernes Bad mit Walk-in-Dusche & Regenduschkopf. Ausstattung:',
      items: ['Handtuchset', 'Duschgel und Shampoo', 'Flüssigseife', 'Reinigungsmittel', 'Toilettenpapier', 'Haartrockner', 'Akkustaubsauger', 'Wäscheständer', 'weiteres Zubehör'],
      images: [
        { src: w17, alt: 'Badezimmer mit Dusche', tip: 'Geräumiges Badezimmer mit Walk-in-Dusche.' },
        { src: w18, alt: 'Badezimmer-Ausstattung', tip: 'Handtücher, Hygieneprodukte und Zubehör.' },
      ],
    },
    parking: {
      title: 'Kostenloser Parkplatz',
      text: 'Bei jedem Haus stehen zwei Parkplätze zur Verfügung. Das Gelände ist eingezäunt und beleuchtet, mit separatem Tor und Pforte.',
    },
    guide: {
      title: 'Gästeführer LAS BIALA\'S',
      qrAlt: 'QR-Code zum LAS BIALA\'S Gästeführer',
    },
  },
}[lang];

const guideHref = {
  pl: 'https://lasbialas.pl/info/#/na-miejscu/505',
  en: 'https://lasbialas.pl/info/en/#/on-site/505',
  de: 'https://lasbialas.pl/info/de/#/vor-ort/505',
}[lang];

const h3Class = 'text-[1.3rem] text-center mt-[40px] mb-[15px] font-semibold text-[#2c2c2c]';
const sectionTextClass = 'text-base leading-[1.6] text-brand-black';
const bulletUl = 'flex flex-wrap justify-center gap-y-[6px] gap-x-[16px] my-2.5 p-0 list-none';
const bulletLi = 'm-0 leading-[1.4] text-[1rem] flex items-center';
const bulletMarker = 'inline-block w-[0.45rem] h-[0.45rem] bg-[#2F6940] mr-[.5em] shrink-0';
const miniGrid = 'grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))] justify-center gap-[3px] mt-[40px] mb-[30px] max-[1342px]:grid-cols-2';
const miniImg = 'max-w-full h-auto object-cover cursor-default transition-transform duration-200';
const tipClass = 'invisible opacity-0 w-[320px] bg-black/70 text-white text-center rounded-[5px] p-[5px] absolute top-1/2 left-1/2 -translate-x-1/2 translate-y-[65px] transition-opacity duration-300 font-[Arial] text-[14px] font-normal leading-[1.4] z-[1] pointer-events-none group-hover:visible group-hover:opacity-100 max-[768px]:hidden';
---

<div class="max-w-[73%] border border-[#ccc] rounded-[5px] py-[10px] px-[80px] mx-auto mb-5 bg-white text-base text-center max-[768px]:max-w-[96vw] max-[768px]:p-5 max-[768px]:my-[1px] max-[768px]:mb-5 max-[768px]:text-[0.6rem]">
  <h2 class="text-[24px] text-center mt-5 mb-5 text-brand-black font-bold">{t.title}</h2>
  <p class="text-base leading-[1.6]">{t.intro}</p>

  {/* Bedrooms */}
  <h3 class={h3Class}>{t.bedrooms.title}</h3>
  <div class={sectionTextClass}>
    <p>{t.bedrooms.intro}</p>
    <ul class={bulletUl}>
      {t.bedrooms.items.map((item: string) => (
        <li class={bulletLi}><span class={bulletMarker}></span>{item}</li>
      ))}
    </ul>
  </div>
  <div class={miniGrid}>
    {t.bedrooms.images.map((img: any) => (
      <div class="relative inline-block group">
        <Picture alt={img.alt} width={834} height={834} loading="lazy" src={img.src} formats={['avif', 'webp']} sizes="(max-width: 1342px) 50vw, 25vw" class={miniImg} />
        <span class={tipClass}>{img.tip}</span>
      </div>
    ))}
  </div>

  {/* Living Room */}
  <h3 class={h3Class}>{t.living.title}</h3>
  <div class={sectionTextClass}>
    <p set:html={t.living.intro.replace('{#guide}', guideHref)}></p>
    <ul class={bulletUl}>
      {t.living.items.map((item: string) => (
        <li class={bulletLi}><span class={bulletMarker}></span>{item}</li>
      ))}
    </ul>
  </div>
  <div class={miniGrid}>
    {t.living.images.map((img: any) => (
      <div class="relative inline-block group">
        <Picture alt={img.alt} width={834} height={834} loading="lazy" src={img.src} formats={['avif', 'webp']} sizes="(max-width: 1342px) 50vw, 25vw" class={miniImg} />
        <span class={tipClass}>{img.tip}</span>
      </div>
    ))}
  </div>

  {/* Bathroom */}
  <h3 class={h3Class}>{t.bathroom.title}</h3>
  <div class={sectionTextClass}>
    <p set:html={t.bathroom.intro}></p>
    <ul class={bulletUl}>
      {t.bathroom.items.map((item: string) => (
        <li class={bulletLi}><span class={bulletMarker}></span>{item}</li>
      ))}
    </ul>
  </div>
  <div class={miniGrid}>
    {t.bathroom.images.map((img: any) => (
      <div class="relative inline-block group">
        <Picture alt={img.alt} width={834} height={834} loading="lazy" src={img.src} formats={['avif', 'webp']} sizes="(max-width: 1342px) 50vw, 25vw" class={miniImg} />
        <span class={tipClass}>{img.tip}</span>
      </div>
    ))}
  </div>

  {/* Parking */}
  <h3 class={h3Class}>{t.parking.title}</h3>
  <div class={sectionTextClass}>
    <p>{t.parking.text}</p>
  </div>

  {/* Guide QR */}
  <h3 class={h3Class}>{t.guide.title}</h3>
  <div class={sectionTextClass}>
    <a href={lang === 'de' ? 'https://lasbialas.pl/info/de/' : 'https://lasbialas.pl/info/'} target="_blank" rel="noopener noreferrer">
      <Picture class="max-w-[20%] h-auto transition-transform hover:scale-[1.05] max-[768px]:max-w-[55%] inline-block" src={lasbialasqrc} alt={t.guide.qrAlt} width={150} height={150} formats={['avif', 'webp']} sizes="150px" />
    </a>
  </div>
</div>
