---
import { getEntry } from 'astro:content';

interface Props {
  lang: 'pl' | 'en' | 'de';
}

const { lang } = Astro.props;
const siteConfig = await getEntry('site', 'config');
const promoBar: any = siteConfig?.data.promoBar ?? { enabled: false, messages: {} };
const currentMessage = promoBar.messages[lang] ?? '';
---

{
  promoBar.enabled && currentMessage && (
    <div class="w-full bg-brand-orange py-[10px] px-[15px] text-brand-black text-center text-[15px] relative z-[3000]">
      <Fragment set:html={currentMessage} />
    </div>
  )
}
