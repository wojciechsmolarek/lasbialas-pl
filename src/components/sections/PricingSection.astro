      ['Jacuzzi (optional)', 'gemäß <a href="#cennik-jacuzzi" class="text-brand-green underline">Preisliste</a>'],
    ],
    reserve: 'Reservierung',
    freeTitle: 'Kostenlos für Gäste',
    freeItems: ['Sauna', 'Abkühlbottich mit Wasser', 'Bademäntel und Saunatücher', '4 Trekking-Fahrräder', 'tragbarer Grill', 'Kohle, Anzünder und Grillzubehör', '4 SUP-Boards (von Mai bis Oktober)'],
    dayInfo: 'Der Aufenthalt dauert von 16:00 bis 12:00 (andere Zeiten nach Absprache möglich). Es fallen keine Zählergebühren an. Wir stellen eine Rechnung mit MwSt. aus. Weitere Details zur Ausstattung, zu den Annehmlichkeiten und zum Aufenthalt findest du in unserem <a href="{#guide}" target="_blank" class="text-brand-green underline">Leitfaden</a>.',
    benefits: ['die besten Preise', 'Aufenthalte ab 2 Nächten', 'flexible Check-in/out-Zeiten', '5 % auf den nächsten Aufenthalt', 'Möglichkeit zur Terminänderung', 'Rabatt für Aufenthalte ab 3 Nächten'],
    footerText: 'Detaillierte Preise und Hausregeln finden Sie im <b><a href="{#guide}" target="_blank" class="text-brand-green underline">Gästeführer</a></b>',
    guideBtn: 'Reiseführer',
  },
}[lang];

const guideHref = {
  pl: 'https://lasbialas.pl/info/',
  en: '/przewodnik/',
  de: 'https://info.lasbialas.pl/de/',
}[lang];

const colW = ['w-[40%] max-[768px]:w-[38%]', 'w-[30%] max-[768px]:w-[30%]', 'w-[30%] max-[768px]:w-[32%]'];

const tableClass = 'w-full max-w-[900px] border-collapse text-base max-[768px]:text-[0.8rem] my-[30px] mx-auto bg-[#f4f4f4] border-2 border-white text-center table-fixed max-[768px]:table-auto';
const thClass = 'bg-[#362e27] text-white font-semibold px-[6px] py-[4px] h-[40px] border-2 border-white align-middle max-[768px]:text-[0.7rem] max-[768px]:leading-[1.2] max-[768px]:break-words max-[768px]:whitespace-normal';
const tdClass = 'h-[60px] p-[6px] border-2 border-white align-middle max-[768px]:text-[0.75rem] max-[768px]:h-[48px] max-[768px]:break-words';
---

<div class="max-w-[73%] border border-[#ccc] rounded-[5px] py-[10px] px-[80px] mx-auto mb-5 bg-white text-base text-center max-[768px]:max-w-[96vw] max-[768px]:p-5 max-[768px]:my-[1px] max-[768px]:mb-5 max-[768px]:text-[0.75rem]">
  <h2 class="text-[24px] max-[768px]:text-[1.1rem] text-center mt-5 mb-5 text-brand-black font-bold">{t.title}</h2>

  {/* Main pricing table */}
  <table class={tableClass}>
    <thead>
      <tr>
        {t.cols.map((col: string, i: number) => (
          <th class={`${thClass} ${colW[i] || ''}`} set:html={col}></th>
        ))}
      </tr>
    </thead>
    <tbody>
      {t.rows.map((row: string[]) => (
        <tr>
          {row.map((cell: string) => (
            <td class={tdClass} set:html={cell}></td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>

  {/* Notes */}
  <div class="max-w-[82%] max-[768px]:max-w-[98vw] border border-brand-green rounded-[5px] p-[5px] my-[5px] mx-auto bg-white text-[1.2rem] max-[768px]:text-[0.8rem] text-brand-green text-center">
    {t.notes.map((note: string) => (
      <p class="my-[5px]" set:html={note}></p>
    ))}
  </div>

  {/* Amenities table */}
  <table class={tableClass}>
    <thead>
      <tr>
        <th class={`${thClass} w-[60%]`} set:html={t.amenitiesCols[0]}></th>
        <th class={`${thClass} w-[40%]`} set:html={t.amenitiesCols[1]}></th>
      </tr>
    </thead>
    <tbody>
      {t.amenitiesRows.map((row: string[]) => (
        <tr>
          <td class={tdClass} set:html={row[0]}></td>
          <td class={tdClass} set:html={row[1]}></td>
        </tr>
      ))}
    </tbody>
  </table>

  {/* Reserve button */}
  <div class="flex justify-center mt-[30px]">
    <a aria-label="Otwórz panel rezerwacji" class="flex justify-center items-center w-[140px] h-[46px] text-base font-normal text-white bg-[#2F6940] border-none text-center no-underline normal-case cursor-pointer font-montserrat mb-[30px] hover:bg-[#40a95c] transition-colors" href="#" onclick="openReservation(); return false;">{t.reserve}</a>
  </div>

  {/* Free items */}
  <h3 class="text-[1.3rem] max-[768px]:text-[1rem] text-center mt-[40px] mb-[15px] font-semibold text-[#2c2c2c]">{t.freeTitle}</h3>
  <div class="text-base leading-[1.6] text-brand-black">
    <ul class="flex flex-wrap justify-center gap-y-[6px] gap-x-[16px] my-2.5 p-0 list-none">
      {t.freeItems.map((item: string) => (
        <li class="m-0 leading-[1.4] text-[1rem] flex items-center">
          <span class="inline-block w-[0.45rem] h-[0.45rem] bg-[#2F6940] mr-[.5em] shrink-0"></span>{item}
        </li>
      ))}
    </ul>
  </div>

  {/* Day info & footer */}
  <p class="text-base leading-[1.6]" set:html={t.dayInfo.replace('{#guide}', guideHref)}></p>

  <div class="flex justify-center mt-[30px]">
    <a class="inline-flex justify-center items-center w-auto h-[46px] text-base font-normal text-white bg-[#E97E2D] border-none text-center no-underline normal-case cursor-pointer mb-[30px] mt-[10px] px-[15px] hover:bg-[#c4621a] transition-colors" href={guideHref} target="_blank">{t.guideBtn}</a>
  </div>
</div>
